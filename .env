# .env

# ==========================================
# BACKEND SECRETS (Hidden from the browser)
# ==========================================
# Use these in your Node.js backend, Edge Functions, or Next.js routes
VITE_GEMINI_API_KEY=""

# ==========================================
# FRONTEND VARIABLES (Exposed to the browser)
# ==========================================
# In Vite, variables MUST start with "VITE_" to be accessible in your React code
VITE_API_BASE_URL="http://localhost:8080/api"
VITE_APP_NAME="NextCraft Schema Workspace"